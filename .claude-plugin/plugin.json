{
  "name": "web-kit",
  "description": "Lightweight web search + scraping + download: SearxNG metasearch, fallback Chrome fetch, CDP file download.",
  "version": "1.6.1",
  "author": {
    "name": "huangyrcn"
  },
  "userConfig": {
    "cdp_url": {
      "type": "string",
      "title": "CDP endpoint",
      "description": "Chrome DevTools Protocol URL (e.g. http://192.168.1.178:9223)",
      "default": "http://localhost:9223"
    },
    "searxng_url": {
      "type": "string",
      "title": "SearxNG endpoint",
      "description": "SearxNG search engine URL (e.g. http://192.168.1.178:8082)",
      "default": "http://localhost:8082"
    }
  }
}
