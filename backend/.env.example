# Sample environment overrides for backend/docker-compose.yml.
# Copy to backend/.env and edit. backend/.env is gitignored.

# By default, the backend binds host ports (8082, 9223, 6080) to 127.0.0.1
# only — CDP and noVNC give full browser-session takeover, so LAN exposure
# requires an explicit opt-in.
#
# Set this to 0.0.0.0 to expose to all interfaces. When you do, also set
# WEB_KIT_VNC_PASSWORD below.
WEB_KIT_BIND=127.0.0.1

# Password for noVNC (the manual-cookie-login interface on port 6080).
# Required when WEB_KIT_BIND=0.0.0.0. Empty value falls back to no auth
# (only safe with the default 127.0.0.1 binding).
#
# Generate one with: openssl rand -hex 12
WEB_KIT_VNC_PASSWORD=

# ── Auth gateway (Caddy) ──────────────────────────────────────────────
# Single shared key for all three services. Scripts send it as the
# X-API-Key header; noVNC uses it as the HTTP Basic Auth password.
# Generate: openssl rand -hex 32
WEB_KIT_API_KEY=

# bcrypt hash of WEB_KIT_API_KEY, used by Caddy's basic_auth for noVNC.
# Generate after setting the key above:
#   docker run --rm caddy:2.8 caddy hash-password --plaintext "$WEB_KIT_API_KEY"
# Paste the full $2a$... string here (quote it — it contains $).
WEB_KIT_NOVNC_HASH=
# noVNC browser login: username "webkit", password = WEB_KIT_API_KEY (plaintext, not the hash).
