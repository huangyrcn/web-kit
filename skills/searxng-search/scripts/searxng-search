#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = []
# ///
"""
searxng-search v2.0.0 — Cross-environment SearxNG search skill

Works in: OpenClaw (CLI) | Claude Code (CLI) | Antigravity (MCP)

Usage:
  searxng-search "query"                    # top 10 results (default: Google)
  searxng-search "query" --num 5            # limit results
  searxng-search "AI news" --categories news
  searxng-search "query" --lang zh-CN
  searxng-search "query" -e google_scholar  # use one non-default engine
  searxng-search "query" --urls-only        # URL list only (pipe to browser-fetch)

When a category search (e.g. -c news) returns no results, the script
automatically falls back to the default Google engine. This works around
SearxNG's built-in category scrapers failing on non-Latin SERPs.

Environment:
  SEARXNG_URL   SearxNG endpoint (default: http://localhost:8082)
                — matches the host-side port that backend/docker-compose.yml exposes.
                Set this if your backend is on a different host or port.
"""
import sys, json, urllib.parse, urllib.request, urllib.error, argparse, os, socket, ssl, threading

# Fix UnicodeEncodeError on Windows with non-UTF-8 system locales (e.g. zh-CN/GBK).
if sys.platform == "win32":
    os.environ.setdefault("PYTHONUTF8", "1")
    try:
        sys.stdout.reconfigure(encoding="utf-8", errors="replace")
        sys.stderr.reconfigure(encoding="utf-8", errors="replace")
    except AttributeError:
        pass

VERSION = "2.0.0"

# Public CLI aliases use shell-friendly identifiers; SearXNG selects engines by
# the configured engine "name", which can contain spaces or dots.
ENGINE_ALIASES = {
    "google_scholar": "google scholar",
    "semantic_scholar": "semantic scholar",
    "github_code": "github code",
    "crates": "crates.io",
    "lib_rs": "lib.rs",
    "pkg_go_dev": "pkg.go.dev",
    "microsoft_learn": "microsoft learn",
    "annas_archive": "annas archive",
}

ENGINE_DISPLAY_NAMES = {
    "google",
    "bing",
    "duckduckgo",
    "arxiv",
    "openalex",
    "dblp",
    "pubmed",
    "github",
    "hackernews",
    "gitlab",
    "huggingface",
    "npm",
    "pypi",
    "sourcehut",
    "nvd",
    "reddit",
    "wikidata",
    "zlibrary",
    *ENGINE_ALIASES.values(),
}


def _normalize_engine_name(engine):
    if not engine:
        return None
    key = engine.strip().lower().replace("-", "_")
    key = "_".join(key.split())
    return ENGINE_ALIASES.get(key, engine.strip())


def _result_engines(result):
    engines = result.get("engines") or []
    engine = result.get("engine")
    if engine:
        engines.append(engine)
    return {name for name in engines if name}


def _validate_engine_results(requested_engine, results):
    if not requested_engine or not results:
        return

    expected = _require_known_engine(requested_engine)

    mismatches = []
    for result in results:
        engines = _result_engines(result)
        if engines and expected not in engines:
            mismatches.append({
                "title": result.get("title", ""),
                "url": result.get("url", ""),
                "engines": sorted(engines),
            })

    if mismatches:
        raise RuntimeError(json.dumps({
            "error_type": "engine_mismatch",
            "engine": requested_engine,
            "searxng_engine": expected,
            "message": "SearXNG returned results from a different engine than requested.",
            "hint": "The backend may not recognize the requested engine name; check its settings.yml engine names.",
            "mismatches": mismatches[:3],
        }))


def _require_known_engine(engine):
    expected = _normalize_engine_name(engine)
    if expected not in ENGINE_DISPLAY_NAMES:
        raise RuntimeError(json.dumps({
            "error_type": "unknown_engine",
            "engine": engine,
            "message": f"Unknown engine '{engine}'.",
            "hint": "Use one engine from the documented list, e.g. google_scholar, semantic_scholar, arxiv, github, or reddit.",
        }))
    return expected

# --- Tavily support (opt-in via SEARCH_PROVIDER=tavily + TAVILY_API_KEY) ---

def _get_search_provider():
    return os.environ.get("SEARCH_PROVIDER", "searxng").lower()

def tavily_search(query, num=10):
    """Search via Tavily API. Requires tavily-python and TAVILY_API_KEY."""
    try:
        from tavily import TavilyClient
    except ImportError:
        raise RuntimeError("tavily-python not installed. Run: pip install tavily-python")
    api_key = os.environ.get("TAVILY_API_KEY")
    if not api_key:
        raise RuntimeError("TAVILY_API_KEY env var is not set")
    client = TavilyClient(api_key=api_key)
    response = client.search(query=query, max_results=min(num, 20), search_depth="basic")
    return response.get("results", [])

def _search_url():
    # Default matches backend/docker-compose.yml host port (8082).
    # Override via SEARXNG_URL when backend is on a different host/port.
    base = os.environ.get("SEARXNG_URL") or os.environ.get("CLAUDE_PLUGIN_OPTION_SEARXNG_URL", "http://localhost:8082")
    return base.rstrip("/") + "/search"

def _api_key():
    key = os.environ.get("WEB_KIT_API_KEY") or os.environ.get("CLAUDE_PLUGIN_OPTION_WEB_KIT_API_KEY")
    if not key:
        print(json.dumps({"error_type": "no_api_key",
            "message": "WEB_KIT_API_KEY not set — required to reach the web-kit gateway",
            "hint": "export WEB_KIT_API_KEY=<your key>"}), file=sys.stderr)
        sys.exit(1)
    return key


def _run_with_timeout(fn, timeout):
    """Run fn() in a thread with a wall-clock timeout. Returns result or raises."""
    result, error = [], []
    def target():
        try:
            result.append(fn())
        except Exception as e:
            error.append(e)
    t = threading.Thread(target=target, daemon=True)
    t.start()
    t.join(timeout)
    if t.is_alive():
        raise socket.timeout("timed out")
    if error:
        raise error[0]
    return result[0]


def search(query, num=10, engines=None, lang=None, categories=None, timeout=30):
    """Search. Returns dict with results, unresponsive_engines, raw."""
    params = {"q": query, "format": "json", "pageno": 1}
    requested_engine = engines
    if engines:
        params["engines"] = _require_known_engine(engines)
    elif not categories:
        params["engines"] = "google"
    if lang:       params["language"] = lang
    if categories: params["categories"] = categories

    url = _search_url() + "?" + urllib.parse.urlencode(params)

    try:
        def do_request():
            req = urllib.request.Request(url, headers={"X-API-Key": _api_key()})
            resp = urllib.request.urlopen(req, timeout=timeout)
            return resp.read().decode("utf-8")
        raw = _run_with_timeout(do_request, timeout + 5)
    except urllib.error.HTTPError as e:
        if e.code == 401:
            raise RuntimeError(json.dumps({"error_type": "unauthorized",
                "message": "Gateway rejected the API key (HTTP 401)",
                "hint": "check WEB_KIT_API_KEY matches the server"}))
        body = e.read().decode("utf-8", errors="replace")[:500] if e.fp else ""
        raise RuntimeError(json.dumps({
            "error_type": "http_error",
            "http_status": e.code,
            "url": url,
            "stderr": body or "(empty)",
            "hint": f"SearxNG returned HTTP {e.code}. Check SEARXNG_URL and server logs.",
        }))
    except socket.timeout:
        raise RuntimeError(json.dumps({
            "error_type": "timeout",
            "url": url,
            "hint": "query too slow",
        }))
    except urllib.error.URLError as e:
        reason = e.reason
        if isinstance(reason, socket.timeout):
            error_type, hint = "timeout", "query too slow"
        elif isinstance(reason, ConnectionRefusedError):
            error_type, hint = "backend_unreachable", f"is SearxNG running at {_search_url()}?"
        elif isinstance(reason, (socket.gaierror, socket.herror)):
            error_type, hint = "dns", "check SEARXNG_URL hostname resolution"
        elif isinstance(reason, ssl.SSLError):
            error_type, hint = "tls", f"TLS error connecting to {_search_url()}. Check certificates."
        else:
            error_type, hint = "network_error", ""
        raise RuntimeError(json.dumps({
            "error_type": error_type,
            "url": url,
            "message": str(reason),
            "hint": hint,
        }))
    except ssl.SSLError as e:
        raise RuntimeError(json.dumps({
            "error_type": "tls",
            "url": url,
            "message": str(e),
            "hint": f"TLS error connecting to {_search_url()}. Check certificates.",
        }))
    except OSError as e:
        if isinstance(e, socket.timeout):
            raise RuntimeError(json.dumps({
                "error_type": "timeout",
                "url": url,
                "hint": "query too slow",
            }))
        raise RuntimeError(json.dumps({
            "error_type": "network_error",
            "url": url,
            "message": str(e),
        }))

    try:
        data = json.loads(raw)
    except json.JSONDecodeError as e:
        raise RuntimeError(json.dumps({
            "error_type": "bad_response",
            "message": f"SearxNG returned non-JSON: {e}",
            "first_200_bytes": raw[:200],
        }))

    results = data.get("results", [])[:num]
    _validate_engine_results(requested_engine, results)

    return {
        "results": results,
        "unresponsive_engines": data.get("unresponsive_engines", []),
        "number_of_results": data.get("number_of_results", 0),
    }

def fmt_results(results, urls_only=False, unresponsive=None):
    if urls_only:
        return "\n".join(r.get("url", "") for r in results)
    lines = []
    for i, r in enumerate(results, 1):
        title   = r.get("title", "").strip()
        url     = r.get("url", "")
        content = r.get("content", "").strip()
        engines = ",".join(r.get("engines", []))
        lines.append(f"[{i}] {title}")
        lines.append(f"    {url}")
        if content: lines.append(f"    {content[:200]}")
        if engines: lines.append(f"    [{engines}]")
        lines.append("")
    out = "\n".join(lines).strip()
    if unresponsive:
        notes = ", ".join(f"{name}({reason})" for name, reason in unresponsive)
        out += f"\n\n[!] Unresponsive engines: {notes}"
    return out

def searxng_search(query, num=15):
    """MCP/legacy interface — returns JSON string."""
    try:
        bundle = search(query, num)
        return json.dumps({
            "query": query,
            "results": bundle["results"],
            "unresponsive_engines": bundle["unresponsive_engines"],
        }, ensure_ascii=False, indent=2)
    except RuntimeError as e:
        try:
            err = json.loads(str(e))
        except json.JSONDecodeError:
            err = {"error_type": "internal", "message": str(e)}
        err["query"] = query
        err["results"] = []
        err.setdefault("error", err.get("message", str(e)))
        return json.dumps(err, ensure_ascii=False)
    except Exception as e:
        return json.dumps({"query": query, "results": [], "error_type": "internal", "error": str(e), "message": str(e)}, ensure_ascii=False)

def main():
    p = argparse.ArgumentParser(description="SearxNG search (cross-environment)")
    p.add_argument("query")
    p.add_argument("--num",        "-n", type=int, default=10)
    p.add_argument("--engines",    "-e", help=(
        "Single engine to use instead of the default Google engine. "
        "Run separate searches to compare engines. Available engines: "
        "google, bing, duckduckgo, arxiv, google_scholar, semantic_scholar, "
        "openalex, dblp, pubmed, github, github_code, gitlab, hackernews, "
        "huggingface, npm, pypi, crates, lib_rs, pkg_go_dev, sourcehut, "
        "microsoft_learn, nvd, reddit, wikidata, annas_archive, zlibrary. "
        "Default: google."
    ))
    p.add_argument("--lang",       "-l", help="zh-CN, en, ja, ko")
    p.add_argument("--categories", "-c", help="general,news,images,science,it,videos,social,files")
    p.add_argument("--timeout",    "-t", type=int, default=30,
                                          help="request timeout in seconds (default: 30)")
    p.add_argument("--json",       "-j", action="store_true", help=argparse.SUPPRESS)
    p.add_argument("--urls-only",  "-u", action="store_true")
    p.add_argument("--version",    "-V", action="version", version=f"searxng-search {VERSION}")
    args = p.parse_args()

    try:
        if args.engines and "," in args.engines:
            raise RuntimeError(json.dumps({
                "error_type": "multiple_engines_not_supported",
                "message": "-e accepts exactly one engine. Run separate searches to compare engines.",
                "hint": "Use the default Google search first; for another source, retry with one engine, e.g. -e google_scholar.",
                "engines": [engine.strip() for engine in args.engines.split(",") if engine.strip()],
            }))

        provider = _get_search_provider()
        if provider == "tavily":
            results = tavily_search(args.query, args.num)
            unresponsive = []
        else:
            bundle = search(args.query, args.num, args.engines, args.lang,
                            args.categories, args.timeout)
            results = bundle["results"]
            unresponsive = bundle["unresponsive_engines"]
    except RuntimeError as e:
        # Already-structured JSON error from search()
        try:
            err = json.loads(str(e))
        except json.JSONDecodeError:
            err = {"error_type": "internal", "message": str(e)}
        err["query"] = args.query
        print(json.dumps(err, ensure_ascii=False))
        sys.exit(1)
    except Exception as e:
        print(json.dumps({"error_type": "internal", "message": str(e),
                          "query": args.query}, ensure_ascii=False))
        sys.exit(1)

    # --- Category fallback ---
    # SearxNG's built-in category scrapers (news, images, etc.) may fail on
    # non-Latin queries.  When a category search returns nothing, retry with
    # the default Google engine (backed by Chrome SERP rendering) so the
    # caller still gets useful results.
    fallback_note = ""
    if not results and args.categories and not args.engines:
        try:
            fb = search(args.query, args.num, engines=None, lang=args.lang,
                        categories=None, timeout=args.timeout)
            if fb["results"]:
                results = fb["results"]
                unresponsive = fb["unresponsive_engines"]
                fallback_note = (
                    f"[!] Category '{args.categories}' returned 0 results "
                    f"(SearxNG scrapers may not support this language/region). "
                    f"Fell back to default Google search.\n\n"
                )
        except Exception:
            pass  # fallback failed silently — report original empty state below

    if not results:
        # Empty results — surface unresponsive engines so caller can act
        out = {"error_type": "no_results", "query": args.query}
        if unresponsive:
            out["unresponsive_engines"] = unresponsive
            out["hint"] = "some engines are quarantined"
        print(json.dumps(out, ensure_ascii=False)); sys.exit(1)

    if getattr(args, "json"):
        print(json.dumps({
            "query": args.query,
            "results": results,
            "unresponsive_engines": unresponsive,
            "fallback": bool(fallback_note),
        }, ensure_ascii=False, indent=2))
    else:
        output = fmt_results(results, args.urls_only, unresponsive)
        if fallback_note:
            output = fallback_note + output
        print(output)

if __name__ == "__main__":
    main()
