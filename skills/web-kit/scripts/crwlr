#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = ["crawl4ai>=0.7.0"]
# ///
"""
crwlr — Web page crawler using crawl4ai with remote Chrome via CDP.

Wraps crawl4ai's AsyncWebCrawler, connecting to a remote Chrome instance
for JS-rendered page extraction. Supports markdown output, Q&A, structured
extraction, and deep crawling.

Usage:
  crwlr crawl -o md "https://example.com"              # Page to markdown
  crwlr crawl -O out.md "https://example.com"          # Save to file
  crwlr crawl -q "what is this about?" "https://..."   # Q&A (requires LLM)
  crwlr crawl -j "extract data" -o json "https://..."  # Structured extraction
  crwlr crawl --deep-crawl bfs --max-pages 20 "https://..."  # Deep crawl
  crwlr crawl -bc "https://example.com"                # Bypass cache
  crwlr --raw crawl -o md "https://..."                # Use local browser

Environment:
  CDP_URL          Chrome DevTools Protocol endpoint (required, e.g. http://localhost:9223)
  OPENAI_API_KEY   Required for -q and -j (LLM extraction) features
"""

import sys
import os
import json
import argparse
import asyncio
import subprocess


def make_parser():
    p = argparse.ArgumentParser(
        prog="crwlr",
        description="Web page crawler using crawl4ai with remote Chrome via CDP",
    )
    p.add_argument("--raw", action="store_true",
                   help="Call crwl directly (local browser, skip CDP config)")
    sub = p.add_subparsers(dest="command")

    crawl = sub.add_parser("crawl", help="Crawl a URL")
    crawl.add_argument("url", help="URL to crawl")
    crawl.add_argument("-o", "--output", default="md",
                       choices=["md", "md-fit", "json", "all"],
                       help="Output format (default: md)")
    crawl.add_argument("-O", "--save-to", dest="save_to",
                       help="Save output to file")
    crawl.add_argument("-q", "--question",
                       help="Ask a question about the page (requires LLM)")
    crawl.add_argument("-j", "--extract",
                       help="Structured extraction instruction (requires LLM)")
    crawl.add_argument("-s", "--schema",
                       help="JSON schema file for extraction")
    crawl.add_argument("--deep-crawl", dest="deep_crawl",
                       choices=["bfs", "dfs"],
                       help="Deep crawl strategy")
    crawl.add_argument("--max-pages", dest="max_pages", type=int, default=10,
                       help="Max pages for deep crawl (default: 10)")
    crawl.add_argument("-bc", "--bypass-cache", dest="bypass_cache",
                       action="store_true", help="Bypass cache")
    crawl.add_argument("--raw-crawl", dest="raw_crawl", action="store_true",
                       help=argparse.SUPPRESS)
    return p


async def run_crawl(args):
    from crawl4ai import (
        AsyncWebCrawler, BrowserConfig, CrawlerRunConfig, CacheMode,
    )

    cdp_url = os.environ.get("CDP_URL") or os.environ.get("CLAUDE_PLUGIN_OPTION_CDP_URL")
    if not cdp_url:
        print("crwlr: CDP_URL environment variable or plugin config is required", file=sys.stderr)
        print("  export CDP_URL=http://your-cdp-host:9223", file=sys.stderr)
        sys.exit(1)

    browser_config = BrowserConfig(
        browser_type="chromium",
        browser_mode="custom",
        cdp_url=cdp_url,
        headless=True,
    )

    # Build run config
    run_kwargs = {}
    if args.bypass_cache:
        run_kwargs["cache_mode"] = CacheMode.BYPASS

    # Deep crawl
    if args.deep_crawl:
        from crawl4ai.deep_crawling import BFSDeepCrawlStrategy
        strategy = BFSDeepCrawlStrategy(
            max_depth=args.max_pages,
        )
        run_kwargs["deep_crawl_strategy"] = strategy

    # LLM extraction (-q or -j)
    extraction_strategy = None
    if args.question or args.extract:
        api_key = os.environ.get("OPENAI_API_KEY")
        if not api_key:
            print("crwlr: -q and -j require OPENAI_API_KEY", file=sys.stderr)
            print("  export OPENAI_API_KEY=sk-...", file=sys.stderr)
            sys.exit(1)

        from crawl4ai import LLMExtractionStrategy, LLMConfig
        llm_config = LLMConfig(
            provider="openai/gpt-4o-mini",
            api_token=api_key,
        )
        instruction = args.question or args.extract
        extraction_strategy = LLMExtractionStrategy(
            llm_config=llm_config,
            instruction=instruction,
        )
        run_kwargs["extraction_strategy"] = extraction_strategy

    run_config = CrawlerRunConfig(**run_kwargs)

    async with AsyncWebCrawler(config=browser_config) as crawler:
        result = await crawler.arun(url=args.url, config=run_config)

    # Format output
    output = None

    if extraction_strategy and result.extracted_content:
        output = result.extracted_content
    elif args.output == "md":
        output = result.markdown if isinstance(result.markdown, str) else result.markdown.raw_markdown
    elif args.output == "md-fit":
        md = result.markdown
        output = md.fit_markdown if hasattr(md, "fit_markdown") and md.fit_markdown else (
            md.raw_markdown if hasattr(md, "raw_markdown") else str(md))
    elif args.output == "json":
        data = {
            "url": result.url,
            "title": getattr(result, "title", ""),
            "markdown": result.markdown if isinstance(result.markdown, str) else str(result.markdown),
            "links": getattr(result, "links", {}),
        }
        output = json.dumps(data, ensure_ascii=False, indent=2)
    elif args.output == "all":
        md = result.markdown if isinstance(result.markdown, str) else str(result.markdown)
        data = {
            "url": result.url,
            "title": getattr(result, "title", ""),
            "markdown": md,
            "links": getattr(result, "links", {}),
        }
        output = json.dumps(data, ensure_ascii=False, indent=2)

    if output is None:
        output = result.markdown if isinstance(result.markdown, str) else str(result.markdown)

    # Write output
    if args.save_to:
        with open(args.save_to, "w", encoding="utf-8") as f:
            f.write(output)
        print(f"Saved: {args.save_to} ({len(output)} chars)")
    else:
        print(output)


def run_raw(argv):
    """Call crwl directly, bypassing CDP config."""
    crwl_bin = os.environ.get("CRWL_BIN", "crwl")
    try:
        result = subprocess.run([crwl_bin] + argv, check=False)
        sys.exit(result.returncode)
    except FileNotFoundError:
        print(f"crwlr: {crwl_bin} not found", file=sys.stderr)
        sys.exit(1)


def main():
    # Handle --raw: pass everything after --raw to crwl directly
    if "--raw" in sys.argv:
        idx = sys.argv.index("--raw")
        raw_args = sys.argv[1:idx] + sys.argv[idx+1:]
        run_raw(raw_args)
        return

    parser = make_parser()
    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    if args.command != "crawl":
        parser.print_help()
        sys.exit(1)

    asyncio.run(run_crawl(args))


if __name__ == "__main__":
    main()
