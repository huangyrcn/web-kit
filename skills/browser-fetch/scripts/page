#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = ["crawl4ai>=0.7.0"]
# ///
"""
browser-fetch page — Render a web page to markdown via a real Chrome browser (CDP).

Fetches a URL through a remote Chrome instance, executes JS, and converts the
rendered page to clean markdown. Handles anti-scraping and JS-heavy SPAs.

Usage:
  browser-fetch page -O out.md "https://example.com"          # Fetch and save (recommended)
  browser-fetch page -o md "https://example.com"               # Output to stdout
  browser-fetch page --deep-crawl bfs --max-depth 20 -O out.md "https://..."  # Deep crawl
  browser-fetch page -bc -O out.md "https://example.com"       # Bypass cache
  browser-fetch page --raw -o md "https://..."                 # Use local browser

Environment:
  CDP_URL          Chrome DevTools Protocol endpoint (required, e.g. http://localhost:9223)
"""

import sys
import os
import json
import argparse
import asyncio
import subprocess
import warnings

# Fix UnicodeEncodeError on Windows with non-UTF-8 system locales (e.g. zh-CN/GBK).
# Must run before crawl4ai imports rich, which auto-detects console encoding.
if sys.platform == "win32":
    os.environ.setdefault("PYTHONUTF8", "1")
    try:
        sys.stdout.reconfigure(encoding="utf-8", errors="replace")
        sys.stderr.reconfigure(encoding="utf-8", errors="replace")
    except AttributeError:
        pass


def make_parser():
    p = argparse.ArgumentParser(
        prog="browser-fetch page",
        description="Web page fetcher using a real Chrome browser via CDP",
    )
    p.add_argument("--raw", action="store_true",
                   help="Call crwl directly (local browser, skip CDP config)")
    p.add_argument("url", help="URL to crawl")
    p.add_argument("-o", "--output", default="md",
                   choices=["md", "md-fit", "json", "all"],
                   help="Output format (default: md)")
    p.add_argument("-O", "--save-to", dest="save_to",
                   help="Save output to file (recommended)")
    p.add_argument("--deep-crawl", dest="deep_crawl",
                   choices=["bfs", "dfs"],
                   help="Deep crawl strategy")
    p.add_argument("--max-depth", dest="max_depth", type=int, default=10,
                   help="Max link-hop depth for deep crawl (default: 10)")
    p.add_argument("-bc", "--bypass-cache", dest="bypass_cache",
                   action="store_true", help="Bypass cache")
    p.add_argument("--raw-crawl", dest="raw_crawl", action="store_true",
                   help=argparse.SUPPRESS)
    return p


async def run_crawl(args):
    # --- fail-closed checks BEFORE importing crawl4ai (heavy dep) ---
    cdp_url = os.environ.get("CDP_URL") or os.environ.get("CLAUDE_PLUGIN_OPTION_CDP_URL")
    if not cdp_url:
        print("browser-fetch page: CDP_URL environment variable or plugin config is required", file=sys.stderr)
        print("  export CDP_URL=http://your-cdp-host:9223", file=sys.stderr)
        sys.exit(1)

    api_key = os.environ.get("WEB_KIT_API_KEY") or os.environ.get("CLAUDE_PLUGIN_OPTION_WEB_KIT_API_KEY")
    if not api_key:
        print("browser-fetch page: WEB_KIT_API_KEY not set — required to reach the web-kit gateway", file=sys.stderr)
        sys.exit(1)

    # crawl4ai calls connect_over_cdp without headers; patch it to inject our
    # gateway key on the CDP connection (both playwright and patchright variants).
    from playwright.async_api import BrowserType as _PWBrowserType
    _orig_cdp = _PWBrowserType.connect_over_cdp
    async def _cdp_with_key(self, endpoint_url, **kw):
        headers = {**(kw.pop("headers", None) or {}), "X-API-Key": api_key}
        return await _orig_cdp(self, endpoint_url, headers=headers, **kw)
    _PWBrowserType.connect_over_cdp = _cdp_with_key

    try:
        from patchright.async_api import BrowserType as _PRBrowserType
        _orig_pr = _PRBrowserType.connect_over_cdp
        async def _pr_cdp_with_key(self, endpoint_url, **kw):
            headers = {**(kw.pop("headers", None) or {}), "X-API-Key": api_key}
            return await _orig_pr(self, endpoint_url, headers=headers, **kw)
        _PRBrowserType.connect_over_cdp = _pr_cdp_with_key
    except ImportError:
        pass

    # Pre-flight: verify CDP endpoint is reachable and the API key is accepted
    # before importing crawl4ai (heavy dep). This gives a structured error instead
    # of crawl4ai's raw "CDP endpoint not ready" exception.
    try:
        import urllib.request as _ureq
        _probe_req = _ureq.Request(
            f"{cdp_url}/json/version",
            headers={"X-API-Key": api_key},
        )
        _ureq.urlopen(_probe_req, timeout=10)
    except _ureq.HTTPError as _e:
        if _e.code == 401:
            print(json.dumps({
                "error_type": "unauthorized",
                "cdp_url": cdp_url,
                "message": "Gateway rejected the API key (HTTP 401)",
                "hint": "Check WEB_KIT_API_KEY matches the server.",
            }), file=sys.stderr)
            sys.exit(1)
        # Other HTTP errors (5xx etc) — CDP is there but unhealthy; let crawl4ai try
    except _ureq.URLError as _e:
        _reason = _e.reason
        _err = {"cdp_url": cdp_url}
        if isinstance(_reason, ConnectionRefusedError):
            _err.update(error_type="cdp_unreachable",
                        message="Connection refused",
                        hint="CDP endpoint is not listening. Check that the Docker container is running and port 9223 is exposed.")
        elif isinstance(_reason, (type(None),)):
            _err.update(error_type="cdp_unreachable",
                        message=str(_e),
                        hint=f"Cannot reach CDP at {cdp_url}. Check the URL and network.")
        else:
            _err.update(error_type="cdp_unreachable",
                        message=str(_reason),
                        hint=f"Cannot reach CDP at {cdp_url}. Check the URL and network.")
        print(json.dumps(_err), file=sys.stderr)
        sys.exit(1)
    except Exception as _e:
        print(json.dumps({
            "error_type": "cdp_unreachable",
            "cdp_url": cdp_url,
            "message": str(_e),
            "hint": f"Cannot reach CDP at {cdp_url}. Check the URL and network.",
        }), file=sys.stderr)
        sys.exit(1)

    # crawl4ai also probes <cdp_url>/json/version with its own aiohttp GET before
    # connecting — that path bypasses connect_over_cdp, so the gateway 401s it and
    # crawl4ai aborts with "CDP verification failed". Inject the key on aiohttp
    # requests too, scoped to the CDP host only (never leak it to third-party sites).
    try:
        import aiohttp as _aiohttp
        from urllib.parse import urlparse as _urlparse
        _cdp_host = _urlparse(cdp_url).netloc
        _orig_request = _aiohttp.ClientSession._request
        def _request_with_key(self, method, str_or_url, **kw):
            try:
                if _urlparse(str(str_or_url)).netloc == _cdp_host:
                    hdrs = dict(kw.get("headers") or {})
                    hdrs.setdefault("X-API-Key", api_key)
                    kw["headers"] = hdrs
            except Exception:
                pass
            return _orig_request(self, method, str_or_url, **kw)
        _aiohttp.ClientSession._request = _request_with_key
    except ImportError:
        pass

    # --- now import crawl4ai (requires chromium playwright to be installed) ---
    from crawl4ai import (
        AsyncWebCrawler, BrowserConfig, CrawlerRunConfig, CacheMode,
    )

    browser_config = BrowserConfig(
        browser_type="chromium",
        browser_mode="custom",
        cdp_url=cdp_url,
        headless=True,
    )

    # Build run config
    run_kwargs = {}
    if args.bypass_cache:
        run_kwargs["cache_mode"] = CacheMode.BYPASS

    # Deep crawl
    if args.deep_crawl:
        if args.deep_crawl == "dfs":
            from crawl4ai.deep_crawling import DFSDeepCrawlStrategy
            strategy = DFSDeepCrawlStrategy(max_depth=args.max_depth)
        else:
            from crawl4ai.deep_crawling import BFSDeepCrawlStrategy
            strategy = BFSDeepCrawlStrategy(max_depth=args.max_depth)
        run_kwargs["deep_crawl_strategy"] = strategy

    run_config = CrawlerRunConfig(**run_kwargs)

    async with AsyncWebCrawler(config=browser_config) as crawler:
        result = await crawler.arun(url=args.url, config=run_config)

    # Format output
    output = None

    if args.output == "md":
        output = result.markdown if isinstance(result.markdown, str) else result.markdown.raw_markdown
    elif args.output == "md-fit":
        md = result.markdown
        output = md.fit_markdown if hasattr(md, "fit_markdown") and md.fit_markdown else (
            md.raw_markdown if hasattr(md, "raw_markdown") else str(md))
    elif args.output == "json":
        data = {
            "url": result.url,
            "title": getattr(result, "title", ""),
            "markdown": result.markdown if isinstance(result.markdown, str) else str(result.markdown),
            "links": getattr(result, "links", {}),
        }
        output = json.dumps(data, ensure_ascii=False, indent=2)
    elif args.output == "all":
        md = result.markdown if isinstance(result.markdown, str) else str(result.markdown)
        data = {
            "url": result.url,
            "title": getattr(result, "title", ""),
            "markdown": md,
            "links": getattr(result, "links", {}),
        }
        output = json.dumps(data, ensure_ascii=False, indent=2)

    if output is None:
        output = result.markdown if isinstance(result.markdown, str) else str(result.markdown)

    # Write output
    if args.save_to:
        with open(args.save_to, "w", encoding="utf-8") as f:
            f.write(output)
        print(f"Saved: {args.save_to} ({len(output)} chars)")
    else:
        print(output)


def run_raw(argv):
    """Call crwl directly, bypassing CDP config."""
    crwl_bin = os.environ.get("CRWL_BIN", "crwl")
    try:
        result = subprocess.run([crwl_bin] + argv, check=False)
        sys.exit(result.returncode)
    except FileNotFoundError:
        print(f"browser-fetch page: {crwl_bin} not found", file=sys.stderr)
        sys.exit(1)


def main():
    # Handle --raw: pass everything after --raw to crwl directly
    if "--raw" in sys.argv:
        idx = sys.argv.index("--raw")
        raw_args = sys.argv[1:idx] + sys.argv[idx+1:]
        run_raw(raw_args)
        return

    parser = make_parser()
    args = parser.parse_args()

    if sys.platform == "win32":
        # Suppress ResourceWarning from asyncio ProactorEventLoop transport
        # cleanup on Windows. The __del__ path triggers repr→fileno on
        # already-closed pipes after asyncio.run() closes the loop.
        # Scoped to this block only — genuine resource leaks elsewhere still warn.
        with warnings.catch_warnings():
            warnings.filterwarnings("ignore", category=ResourceWarning)
            asyncio.run(run_crawl(args))
    else:
        asyncio.run(run_crawl(args))


if __name__ == "__main__":
    main()
