#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = []
# ///
"""
ask-search v1.1.0 — Cross-environment SearxNG search skill

Works in: OpenClaw (CLI) | Claude Code (CLI) | Antigravity (MCP)

Usage:
  ask-search "query"                    # top 10 results (default: google)
  ask-search "query" --num 5            # limit results
  ask-search "AI news" --categories news
  ask-search "query" --lang zh-CN
  ask-search "query" -e arxiv,openalex  # specific engines
  ask-search "query" -e openalex,github # cheap engines (no Chrome)
  ask-search "query" --urls-only        # URL list only (pipe to web_fetch)
  ask-search "query" --json             # raw JSON output

Environment:
  SEARXNG_URL   SearxNG endpoint (default: http://localhost:8082)
                — matches the host-side port that backend/docker-compose.yml exposes.
                Set this if your backend is on a different host or port.
"""
import sys, json, urllib.parse, urllib.request, urllib.error, argparse, os, socket, ssl, threading

# Fix UnicodeEncodeError on Windows with non-UTF-8 system locales (e.g. zh-CN/GBK).
if sys.platform == "win32":
    os.environ.setdefault("PYTHONUTF8", "1")
    try:
        sys.stdout.reconfigure(encoding="utf-8", errors="replace")
        sys.stderr.reconfigure(encoding="utf-8", errors="replace")
    except AttributeError:
        pass

VERSION = "1.1.0"

# --- Tavily support (opt-in via SEARCH_PROVIDER=tavily + TAVILY_API_KEY) ---

def _get_search_provider():
    return os.environ.get("SEARCH_PROVIDER", "searxng").lower()

def tavily_search(query, num=10):
    """Search via Tavily API. Requires tavily-python and TAVILY_API_KEY."""
    try:
        from tavily import TavilyClient
    except ImportError:
        raise RuntimeError("tavily-python not installed. Run: pip install tavily-python")
    api_key = os.environ.get("TAVILY_API_KEY")
    if not api_key:
        raise RuntimeError("TAVILY_API_KEY env var is not set")
    client = TavilyClient(api_key=api_key)
    response = client.search(query=query, max_results=min(num, 20), search_depth="basic")
    return response.get("results", [])

def _search_url():
    # Default matches backend/docker-compose.yml host port (8082).
    # Override via SEARXNG_URL when backend is on a different host/port.
    base = os.environ.get("SEARXNG_URL") or os.environ.get("CLAUDE_PLUGIN_OPTION_SEARXNG_URL", "http://localhost:8082")
    return base.rstrip("/") + "/search"


def _run_with_timeout(fn, timeout):
    """Run fn() in a thread with a wall-clock timeout. Returns result or raises."""
    result, error = [], []
    def target():
        try:
            result.append(fn())
        except Exception as e:
            error.append(e)
    t = threading.Thread(target=target, daemon=True)
    t.start()
    t.join(timeout)
    if t.is_alive():
        raise socket.timeout("timed out")
    if error:
        raise error[0]
    return result[0]


def search(query, num=10, engines=None, lang=None, categories=None, timeout=30):
    """Search. Returns dict with results, unresponsive_engines, raw."""
    params = {"q": query, "format": "json", "pageno": 1}
    if engines:
        params["engines"] = engines
    elif not categories:
        params["engines"] = "google"
    if lang:       params["language"] = lang
    if categories: params["categories"] = categories

    url = _search_url() + "?" + urllib.parse.urlencode(params)

    try:
        def do_request():
            resp = urllib.request.urlopen(url, timeout=timeout)
            return resp.read().decode("utf-8")
        raw = _run_with_timeout(do_request, timeout + 5)
    except urllib.error.HTTPError as e:
        body = e.read().decode("utf-8", errors="replace")[:500] if e.fp else ""
        raise RuntimeError(json.dumps({
            "error_type": "http_error",
            "http_status": e.code,
            "url": url,
            "stderr": body or "(empty)",
            "hint": f"SearxNG returned HTTP {e.code}. Check SEARXNG_URL and server logs.",
        }))
    except socket.timeout:
        raise RuntimeError(json.dumps({
            "error_type": "timeout",
            "url": url,
            "hint": "query too slow; try -e openalex,github,semantic_scholar",
        }))
    except urllib.error.URLError as e:
        reason = e.reason
        if isinstance(reason, socket.timeout):
            error_type, hint = "timeout", "query too slow; try -e arxiv,github,bing to skip Chrome-rendered engines"
        elif isinstance(reason, ConnectionRefusedError):
            error_type, hint = "backend_unreachable", f"is SearxNG running at {_search_url()}?"
        elif isinstance(reason, (socket.gaierror, socket.herror)):
            error_type, hint = "dns", "check SEARXNG_URL hostname resolution"
        elif isinstance(reason, ssl.SSLError):
            error_type, hint = "tls", f"TLS error connecting to {_search_url()}. Check certificates."
        else:
            error_type, hint = "network_error", ""
        raise RuntimeError(json.dumps({
            "error_type": error_type,
            "url": url,
            "message": str(reason),
            "hint": hint,
        }))
    except ssl.SSLError as e:
        raise RuntimeError(json.dumps({
            "error_type": "tls",
            "url": url,
            "message": str(e),
            "hint": f"TLS error connecting to {_search_url()}. Check certificates.",
        }))
    except OSError as e:
        if isinstance(e, socket.timeout):
            raise RuntimeError(json.dumps({
                "error_type": "timeout",
                "url": url,
                "hint": "query too slow; try -e openalex,github,semantic_scholar",
            }))
        raise RuntimeError(json.dumps({
            "error_type": "network_error",
            "url": url,
            "message": str(e),
        }))

    try:
        data = json.loads(raw)
    except json.JSONDecodeError as e:
        raise RuntimeError(json.dumps({
            "error_type": "bad_response",
            "message": f"SearxNG returned non-JSON: {e}",
            "first_200_bytes": raw[:200],
        }))

    return {
        "results": data.get("results", [])[:num],
        "unresponsive_engines": data.get("unresponsive_engines", []),
        "number_of_results": data.get("number_of_results", 0),
    }

def fmt_results(results, urls_only=False, unresponsive=None):
    if urls_only:
        return "\n".join(r.get("url", "") for r in results)
    lines = []
    for i, r in enumerate(results, 1):
        title   = r.get("title", "").strip()
        url     = r.get("url", "")
        content = r.get("content", "").strip()
        engines = ",".join(r.get("engines", []))
        lines.append(f"[{i}] {title}")
        lines.append(f"    {url}")
        if content: lines.append(f"    {content[:200]}")
        if engines: lines.append(f"    [{engines}]")
        lines.append("")
    out = "\n".join(lines).strip()
    if unresponsive:
        notes = ", ".join(f"{name}({reason})" for name, reason in unresponsive)
        out += f"\n\n[!] Unresponsive engines: {notes}"
    return out

def searxng_search(query, num=15):
    """MCP/legacy interface — returns JSON string."""
    try:
        bundle = search(query, num)
        return json.dumps({
            "query": query,
            "results": bundle["results"],
            "unresponsive_engines": bundle["unresponsive_engines"],
        }, ensure_ascii=False, indent=2)
    except RuntimeError as e:
        try:
            err = json.loads(str(e))
        except json.JSONDecodeError:
            err = {"error_type": "internal", "message": str(e)}
        err["query"] = query
        err["results"] = []
        err.setdefault("error", err.get("message", str(e)))
        return json.dumps(err, ensure_ascii=False)
    except Exception as e:
        return json.dumps({"query": query, "results": [], "error_type": "internal", "error": str(e), "message": str(e)}, ensure_ascii=False)

def main():
    p = argparse.ArgumentParser(description="SearxNG search (cross-environment)")
    p.add_argument("query")
    p.add_argument("--num",        "-n", type=int, default=10)
    p.add_argument("--engines",    "-e", help=(
        "Comma-separated engine list: "
        "google, bing, duckduckgo, arxiv, google_scholar, semantic_scholar, "
        "openalex, dblp, pubmed, github, github_code, gitlab, hackernews, "
        "huggingface, npm, pypi, crates, lib_rs, pkg_go_dev, sourcehut, "
        "microsoft_learn, nvd, reddit, wikidata, annas_archive, zlibrary. "
        "Default: google."
    ))
    p.add_argument("--lang",       "-l", help="zh-CN, en, ja, ko")
    p.add_argument("--categories", "-c", help="general,news,images,science,it,videos,social,files")
    p.add_argument("--timeout",    "-t", type=int, default=30,
                                          help="request timeout in seconds (default: 30)")
    p.add_argument("--json",       "-j", action="store_true")
    p.add_argument("--urls-only",  "-u", action="store_true")
    p.add_argument("--version",    "-V", action="version", version=f"ask-search {VERSION}")
    args = p.parse_args()

    try:
        provider = _get_search_provider()
        if provider == "tavily":
            results = tavily_search(args.query, args.num)
            unresponsive = []
        else:
            bundle = search(args.query, args.num, args.engines, args.lang,
                            args.categories, args.timeout)
            results = bundle["results"]
            unresponsive = bundle["unresponsive_engines"]
    except RuntimeError as e:
        # Already-structured JSON error from search()
        try:
            err = json.loads(str(e))
        except json.JSONDecodeError:
            err = {"error_type": "internal", "message": str(e)}
        err["query"] = args.query
        print(json.dumps(err, ensure_ascii=False))
        sys.exit(1)
    except Exception as e:
        print(json.dumps({"error_type": "internal", "message": str(e),
                          "query": args.query}, ensure_ascii=False))
        sys.exit(1)

    if not results:
        # Empty results — surface unresponsive engines so caller can act
        out = {"error_type": "no_results", "query": args.query}
        if unresponsive:
            out["unresponsive_engines"] = unresponsive
            out["hint"] = (
                "Some engines are quarantined. Try -e openalex,github,semantic_scholar,pubmed,dblp"
            )
        print(json.dumps(out, ensure_ascii=False)); sys.exit(1)

    if getattr(args, "json"):
        print(json.dumps({
            "query": args.query,
            "results": results,
            "unresponsive_engines": unresponsive,
        }, ensure_ascii=False, indent=2))
    else:
        print(fmt_results(results, args.urls_only, unresponsive))

if __name__ == "__main__":
    main()
